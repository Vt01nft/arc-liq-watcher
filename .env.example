# Telegram Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# RPC Settings
# For testing: https://rpc.testnet.arc.network
# For mainnet: (Once live, or your guessed Alchemy mainnet URL)
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# Bot Settings
# How often to check for new blocks (in seconds)
POLL_INTERVAL_SECONDS=2

# Start scanning from this block. Can be 'latest' or a block number (integer)
START_BLOCK=latest
